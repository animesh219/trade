# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://tradeflow:tradeflow@localhost:5432/tradeflow
DB_SSL=false

# JWT
JWT_ACCESS_SECRET=change_this_to_a_long_random_string
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (for OTP / password reset) - use a provider like SendGrid, SES, or Mailgun
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_smtp_key
SMTP_FROM="TradeFlow <no-reply@tradeflow.com>"

# SMS OTP (Twilio example)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Binance (use TESTNET keys for development: https://testnet.binance.vision)
BINANCE_API_KEY=your_testnet_api_key
BINANCE_API_SECRET=your_testnet_api_secret
BINANCE_BASE_URL=https://testnet.binance.vision
BINANCE_WS_BASE=wss://testnet.binance.vision

# File uploads (KYC docs)
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=5
